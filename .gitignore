# Dependencies
node_modules/

# Database — persistent data, never commit
data/*.db
data/*.db-journal

# User-uploaded files and generated PDFs
data/uploads/*
data/pdfs/*

# Keep the folder structure so Railway creates the dirs on startup
!data/uploads/.gitkeep
!data/pdfs/.gitkeep

# Environment variables
.env
.env.local

# OS junk
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*
